# Google Maps Platform (Static Maps, Places — Vite dev + Node fetch scripts)
# Vite loads these automatically in `npm run dev`. Node scripts (fetch-photos, fetch-reviews)
# read the same file via scripts/load-env.mjs — set at least GOOGLE_MAPS_API_KEY for those.
VITE_GOOGLE_MAPS_API_KEY=your_key_here
GOOGLE_MAPS_API_KEY=your_key_here
